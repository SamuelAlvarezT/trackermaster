<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:name=".TrackermasterApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Trackermaster">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Trackermaster">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".focus.FocusTimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="focus_timer" />
        </service>

        <receiver
            android:name="com.trackermaster.core.widgets.HabitProgressWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_habits">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_habit_progress" />
        </receiver>
        <receiver
            android:name="com.trackermaster.core.widgets.StreakOverviewWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_streaks">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_streak" />
        </receiver>
        <receiver
            android:name="com.trackermaster.core.widgets.MoodLogWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_mood">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_mood" />
        </receiver>
        <receiver
            android:name="com.trackermaster.core.widgets.ExpenseBalanceWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_balance">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_balance" />
        </receiver>
        <receiver
            android:name="com.trackermaster.core.widgets.FocusQuickStartWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_focus">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_focus" />
        </receiver>
        <receiver
            android:name="com.trackermaster.core.widgets.DashboardComboWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_dashboard">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_dashboard" />
        </receiver>

        <receiver
            android:name=".reminder.ReminderActionReceiver"
            android:exported="false" />

    </application>
</manifest>
